{
  "name": "@georgiosnikitas/brain-break",
  "version": "1.11.0",
  "description": "An AI-powered terminal quiz app",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/georgiosnikitas/brain-break"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "bin": {
    "brain-break": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "postinstall": "patch-package",
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.63",
    "@ai-sdk/google": "^3.0.52",
    "@ai-sdk/openai": "^3.0.47",
    "@github/copilot-sdk": "^0.1.32",
    "@inquirer/prompts": "7.10.1",
    "ai": "^6.0.134",
    "chalk": "^5.0.0",
    "figlet": "^1.11.0",
    "ora": "^8.0.0",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.19.15",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitest/coverage-v8": "^4.1.0",
    "patch-package": "^8.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
