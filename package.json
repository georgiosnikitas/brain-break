{
  "name": "brain-break",
  "version": "1.0.0",
  "description": "An AI-powered terminal quiz app using the GitHub Copilot SDK.",
  "type": "module",
  "bin": {
    "brain-break": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=25.8.0"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chalk": "^5.0.0",
    "inquirer": "^12.0.0",
    "ora": "^8.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
