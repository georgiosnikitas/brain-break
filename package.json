{
  "name": "@georgiosnikitas/brain-break",
  "version": "1.18.0",
  "description": "An AI-powered terminal quiz app",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/georgiosnikitas/brain-break.git"
  },
  "bin": {
    "brain-break": "dist/index.js"
  },
  "files": [
    "dist",
    "patches"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "prepare": "patch-package",
    "postinstall": "patch-package",
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.63",
    "@ai-sdk/google": "^3.0.52",
    "@ai-sdk/openai": "^3.0.47",
    "@ai-sdk/openai-compatible": "^2.0.40",
    "@github/copilot-sdk": "^0.2.1",
    "@inquirer/prompts": "^8.3.2",
    "ai": "^6.0.134",
    "chalk": "^5.0.0",
    "figlet": "^1.11.0",
    "ora": "^9.3.0",
    "patch-package": "^8.0.1",
    "qrcode-terminal": "^0.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.19.15",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.0.18"
  }
}
